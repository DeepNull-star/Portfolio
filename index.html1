<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NAME</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        min-height: 100vh;
        background-color: black;
        background-image: url('https://i.pinimg.com/1200x/d4/aa/20/d4aa2073fe6345ef4bc47350e9e94358.jpg');
        background-repeat: no-repeat;
        background-attachment: fixed;
        background-position: center;
        background-size: cover;
      }
      h1 {
        text-align: center;
        background-color: grey;
        padding: 0.5rem 1rem;
      }
      p {
        text-align: center;
        color: whitesmoke;
        margin-top: 1rem;
        text-shadow: 0 1px 2px rgba(0,0,0,0.8);
      }
    </style>
  </head>
  <body>
    <h1>NAME</h1>
    <p>SUBTITLE</p>
  </body>
</html>
